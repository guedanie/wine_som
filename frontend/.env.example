# Frontend env (Vite). Copy to .env for local dev; set the same keys in Vercel
# for production. All are VITE_-prefixed so Vite exposes them to the client.

# Backend API base URL (defaults to http://localhost:8000 if unset).
VITE_API_URL=http://localhost:8000

# PostHog analytics (free tier). Analytics is a NO-OP unless VITE_POSTHOG_KEY
# is set, so leaving it blank is safe (dev/tests stay silent). The key is a
# public project key (client-side, fine to expose). Create a project at
# posthog.com → Project Settings → Project API Key.
VITE_POSTHOG_KEY=
# US cloud default; use https://eu.i.posthog.com for EU projects.
VITE_POSTHOG_HOST=https://us.i.posthog.com
