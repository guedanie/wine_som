# ─────────────────────────────────────────────
# Supabase — supabase.com (or run locally: npx supabase start)
# ─────────────────────────────────────────────

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# AI / Recommendation
# ─────────────────────────────────────────────

# Anthropic Claude — console.anthropic.com
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Tier 1 — Core Data APIs
# ─────────────────────────────────────────────

# GrapeMinds (wine knowledge: region, grape, tasting notes, drinking window)
# Register: https://grapeminds.eu/developers — free 14-day trial, no CC required
GRAPEMINDS_API_KEY=

# Wine-Searcher (vintage data, critic scores, store-level availability + GPS)
# Apply: https://www.wine-searcher.com/trade/api — 100 free calls/day trial
# Status: key requested 2026-06-02, pending approval
WINE_SEARCHER_API_KEY=

# ─────────────────────────────────────────────
# Tier 2 — Supplementary APIs
# ─────────────────────────────────────────────

# VineRadar (grape variety depth, terroir detail — fallback for GrapeMinds gaps)
# Status: API unreleased — on waitlist, no ETA
VINERADAR_API_KEY=

# Apify (Vivino scraper actor — flavor tags, community taste profile)
# Register: https://apify.com — pay-per-result ~$0.003/result, no subscription
# Actor: https://apify.com/mrbridge/vivino-powerful-scraper
APIFY_API_TOKEN=

# ─────────────────────────────────────────────
# Infrastructure
# ─────────────────────────────────────────────

DATABASE_URL=postgresql+asyncpg://wine:wine@localhost:5432/winedb
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────

ENVIRONMENT=development
SECRET_KEY=changeme-before-prod

# ─────────────────────────────────────────────
# Notes (no API key — contact required)
# ─────────────────────────────────────────────
# GWDB / Global Wine Database: email hello@gwdb.io to get in the access queue
# Not self-serve — apply now so it's available post-launch
